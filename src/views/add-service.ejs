<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Thêm dịch vụ mới - SubTracker</title>
    <link rel="stylesheet" href="/stylesheets/output.css" />
  </head>

  <body
    class="bg-slate-50 font-sans antialiased text-gray-900 min-h-screen flex flex-col"
  >
    <%- include('layouts/header') %>

    <main class="flex-1 flex items-center justify-center py-10 px-6">
      <div
        class="max-w-2xl w-full px-14 py-12 bg-white rounded-[2rem] shadow-2xl shadow-slate-200/60 border border-slate-100"
      >
        <div class="text-center mb-10">
          <div
            class="inline-flex items-center justify-center w-20 h-20 bg-gradient-to-br from-indigo-600 to-purple-600 rounded-3xl shadow-xl shadow-indigo-200 mb-6 transform -rotate-3"
          >
            <svg
              class="w-10 h-10 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <h2
            class="text-3xl font-extrabold text-slate-800 tracking-tight leading-tight"
          >
            Thêm gói đăng ký
          </h2>
          <p class="text-slate-500 mt-3 font-medium">
            Nhập thông tin dịch vụ bạn đang sử dụng
          </p>
        </div>

        <% if (typeof errorMessage !== 'undefined') { %>
        <div
          class="mb-6 p-4 bg-red-50 border border-red-200 text-red-600 rounded-2xl text-sm font-semibold"
        >
          <%= errorMessage %>
        </div>
        <% } %>

        <form
          action="/add-service"
          method="POST"
          enctype="multipart/form-data"
          class="space-y-6"
        >
          <div class="group">
            <label
              for="serviceName"
              class="block text-sm font-bold text-slate-700 mb-2 ml-3 transition-colors group-focus-within:text-indigo-600"
              >Tên dịch vụ</label
            >
            <input
              type="text"
              id="serviceName"
              name="serviceName"
              required
              class="w-full px-8 py-4 bg-slate-50 border border-slate-200 rounded-3xl focus:outline-none focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 focus:bg-white transition-all duration-300 placeholder:text-slate-400"
              placeholder="VD: Netflix, Spotify, Adobe..."
              value="<%= locals.oldServiceName %>"
            />
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="group">
              <label
                for="price"
                class="block text-sm font-bold text-slate-700 mb-2 ml-3 transition-colors group-focus-within:text-indigo-600"
                >Số tiền (VNĐ)</label
              >
              <input
                type="number"
                id="price"
                name="price"
                required
                min="0"
                class="w-full px-8 py-4 bg-slate-50 border border-slate-200 rounded-3xl focus:outline-none focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 focus:bg-white transition-all duration-300 placeholder:text-slate-400"
                placeholder="VD: 99000"
              />
            </div>

            <div class="group">
              <label
                for="billingCycle"
                class="block text-sm font-bold text-slate-700 mb-2 ml-3 transition-colors group-focus-within:text-indigo-600"
                >Chu kỳ</label
              >
              <div class="relative">
                <select
                  id="billingCycle"
                  name="billingCycle"
                  required
                  class="w-full px-8 py-4 bg-slate-50 border border-slate-200 rounded-3xl focus:outline-none focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 focus:bg-white transition-all duration-300 appearance-none cursor-pointer text-slate-700 font-medium"
                >
                  <option value="monthly">Hàng tháng</option>
                  <option value="yearly">Hàng năm</option>
                </select>
                <div
                  class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-5 text-slate-500"
                >
                  <svg
                    class="fill-current h-4 w-4"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                  >
                    <path
                      d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"
                    />
                  </svg>
                </div>
              </div>
            </div>
          </div>

          <div class="group">
            <label
              for="nextPaymentDate"
              class="block text-sm font-bold text-slate-700 mb-2 ml-3 transition-colors group-focus-within:text-indigo-600"
              >Ngày thanh toán kế tiếp</label
            >
            <input
              type="date"
              id="nextPaymentDate"
              name="nextPaymentDate"
              required
              class="w-full px-8 py-4 bg-slate-50 border border-slate-200 rounded-3xl focus:outline-none focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 focus:bg-white transition-all duration-300 text-slate-700 font-medium cursor-pointer"
            />
          </div>

          <div class="group">
            <label
              class="block text-sm font-bold text-slate-700 mb-2 ml-3 transition-colors group-focus-within:text-indigo-600"
            >
              Đính kèm hóa đơn/hình ảnh
              <span class="text-slate-400 font-normal">(Tùy chọn)</span>
            </label>

            <div
              class="relative mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-slate-300 border-dashed rounded-3xl hover:border-indigo-500 hover:bg-indigo-50/50 transition-all duration-300 group-focus-within:border-indigo-500"
              id="drop-area"
            >
              <div class="space-y-2 text-center" id="upload-content">
                <svg
                  class="mx-auto h-12 w-12 text-slate-400"
                  stroke="currentColor"
                  fill="none"
                  viewBox="0 0 48 48"
                  aria-hidden="true"
                >
                  <path
                    d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                <div class="flex text-sm text-slate-600 justify-center">
                  <label
                    for="file-upload"
                    class="relative cursor-pointer rounded-md font-bold text-indigo-600 focus-within:outline-none hover:text-indigo-500"
                  >
                    <span>Tải ảnh lên</span>
                    <input
                      id="file-upload"
                      name="QRCode"
                      type="file"
                      class="sr-only"
                      accept="image/png, image/jpeg, image/webp"
                      onchange="previewImage(event)"
                    />
                  </label>
                  <p class="pl-1">hoặc kéo thả vào đây</p>
                </div>
                <p class="text-xs text-slate-500">PNG, JPG, WEBP lên đến 5MB</p>
              </div>

              <div
                id="image-preview-container"
                class="hidden absolute inset-0 bg-white/90 rounded-3xl flex items-center justify-center p-2 backdrop-blur-sm z-10"
              >
                <img
                  id="image-preview"
                  src="#"
                  alt="Preview"
                  class="max-h-full max-w-full rounded-2xl object-contain shadow-sm border border-slate-200"
                />
                <button
                  type="button"
                  onclick="clearImage()"
                  class="absolute top-3 right-3 p-1.5 bg-red-100 text-red-600 rounded-full hover:bg-red-500 hover:text-white transition-colors shadow-sm"
                >
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M6 18L18 6M6 6l12 12"
                    ></path>
                  </svg>
                </button>
              </div>
            </div>
          </div>
          <button
            type="submit"
            class="w-full bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-bold py-4 rounded-3xl shadow-xl shadow-indigo-200 hover:shadow-indigo-300 hover:translate-y-[-2px] active:scale-95 transition-all duration-200 mt-8 text-lg"
          >
            Lưu thông tin dịch vụ
          </button>
        </form>
      </div>
    </main>

    <script>
      function previewImage(event) {
        const file = event.target.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = function (e) {
            document.getElementById("image-preview").src = e.target.result;
            document
              .getElementById("image-preview-container")
              .classList.remove("hidden");
          };
          reader.readAsDataURL(file);
        }
      }

      function clearImage() {
        document.getElementById("file-upload").value = ""; // Xóa dữ liệu file trong input
        document.getElementById("image-preview").src = "#";
        document
          .getElementById("image-preview-container")
          .classList.add("hidden"); // Ẩn preview đi
      }
    </script>
  </body>
</html>
