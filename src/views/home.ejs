<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Trang chủ - SubTracker</title>
    <link rel="stylesheet" href="/stylesheets/output.css" />
  </head>
  <body class="bg-slate-50 font-sans antialiased text-gray-900">
    <%- include('layouts/header') %>
	<% if(!locals.user) { %>
	<main class="flex-1">
        <section class="relative py-20 overflow-hidden">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
                <div class="text-center">
                    <span class="inline-block px-4 py-1.5 mb-6 text-sm font-bold tracking-widest text-indigo-600 uppercase bg-indigo-50 rounded-full">
                        Giải pháp quản lý chi tiêu số 1
                    </span>
                    <h1 class="text-5xl md:text-7xl font-black text-slate-900 mb-8 tracking-tight">
                        Kiểm soát mọi <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-purple-600">gói đăng ký</span> <br class="hidden md:block"> trong tầm tay bạn.
                    </h1>
                    <p class="max-w-2xl mx-auto text-lg md:text-xl text-slate-500 mb-10 leading-relaxed font-medium">
                        Đừng để những khoản phí gia hạn tự động làm bạn bất ngờ. SubTracker giúp bạn theo dõi, nhắc lịch và tối ưu hóa mọi chi tiêu dịch vụ hàng tháng.
                    </p>
                    <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
                        <a href="/sign_up" class="px-8 py-4 bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-bold rounded-2xl shadow-xl shadow-indigo-200 hover:shadow-indigo-300 hover:-translate-y-1 transition-all duration-300 text-lg w-full sm:w-auto text-center">
                            Bắt đầu miễn phí ngay
                        </a>
                        <a href="#features" class="px-8 py-4 bg-white text-slate-700 font-bold rounded-2xl shadow-sm border border-slate-200 hover:bg-slate-50 transition-all text-lg w-full sm:w-auto text-center">
                            Tìm hiểu thêm
                        </a>
                    </div>
                </div>
            </div>
            
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-0 pointer-events-none">
                <div class="absolute top-10 left-10 w-72 h-72 bg-purple-200 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-pulse"></div>
                <div class="absolute bottom-10 right-10 w-72 h-72 bg-indigo-200 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-pulse transition-delay-2000"></div>
            </div>
        </section>

        <section id="features" class="py-20 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16">
                    <h2 class="text-3xl md:text-4xl font-black text-slate-900 mb-4">Tại sao nên dùng SubTracker?</h2>
                    <div class="h-1.5 w-20 bg-gradient-to-r from-indigo-600 to-purple-600 mx-auto rounded-full"></div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
                    <div class="p-8 bg-slate-50 rounded-[2rem] border border-slate-100 hover:shadow-xl hover:shadow-indigo-50 transition-all duration-300 group">
                        <div class="w-14 h-14 bg-white rounded-2xl shadow-sm flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                            <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <h3 class="text-xl font-bold text-slate-800 mb-3">Nhắc nhở thông minh</h3>
                        <p class="text-slate-500 leading-relaxed font-medium">Nhận thông báo trước khi gói dịch vụ của bạn tự động gia hạn 1-2 ngày.</p>
                    </div>

                    <div class="p-8 bg-slate-50 rounded-[2rem] border border-slate-100 hover:shadow-xl hover:shadow-indigo-50 transition-all duration-300 group border-indigo-100 bg-indigo-50/30">
                        <div class="w-14 h-14 bg-indigo-600 rounded-2xl shadow-lg flex items-center justify-center mb-6 group-hover:rotate-6 transition-transform">
                            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                        </div>
                        <h3 class="text-xl font-bold text-slate-800 mb-3 text-indigo-700">Thống kê trực quan</h3>
                        <p class="text-slate-500 leading-relaxed font-medium text-slate-600">Biết chính xác bạn đang chi bao nhiêu tiền mỗi tháng cho các dịch vụ số.</p>
                    </div>

                    <div class="p-8 bg-slate-50 rounded-[2rem] border border-slate-100 hover:shadow-xl hover:shadow-indigo-50 transition-all duration-300 group">
                        <div class="w-14 h-14 bg-white rounded-2xl shadow-sm flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                            <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                        </div>
                        <h3 class="text-xl font-bold text-slate-800 mb-3">Bảo mật tuyệt đối</h3>
                        <p class="text-slate-500 leading-relaxed font-medium">Dữ liệu của bạn được mã hóa và bảo vệ an toàn với công nghệ mới nhất.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="py-20">
            <div class="max-w-5xl mx-auto px-4">
                <div class="bg-gradient-to-br from-indigo-600 to-purple-700 rounded-[3rem] p-12 text-center shadow-2xl shadow-indigo-200">
                    <h2 class="text-3xl md:text-5xl font-black text-white mb-6">Sẵn sàng để quản lý <br> chi tiêu tốt hơn?</h2>
                    <p class="text-indigo-100 mb-10 text-lg font-medium">Tham gia cùng hơn 1,000 người dùng đang tiết kiệm tiền mỗi ngày.</p>
                    <a href="/sign_up" class="px-10 py-5 bg-white text-indigo-600 font-black rounded-2xl shadow-xl hover:bg-slate-50 hover:scale-105 active:scale-95 transition-all text-lg inline-block">
                        Tạo tài khoản ngay bây giờ
                    </a>
                </div>
            </div>
        </section>
    </main>

    <footer class="bg-white border-t border-slate-100 py-12">
        <div class="text-center text-slate-400 font-medium text-sm">
            &copy; 2026 SubTracker. Thiết kế bởi Nguyễn Ngọc Tài.
        </div>
    </footer>
	<% } else { %>
    <main
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 animate-fade-in-up"
    >
      <div
        class="bg-indigo-600 rounded-3xl p-8 sm:p-10 mb-8 shadow-xl shadow-indigo-200 relative overflow-hidden"
      >
        <div
          class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-white opacity-10 rounded-full blur-2xl"
        ></div>
        <div
          class="absolute bottom-0 left-0 -mb-16 -ml-16 w-48 h-48 bg-purple-500 opacity-20 rounded-full blur-xl"
        ></div>

        <div class="relative z-10">
          <h1 class="text-3xl sm:text-4xl font-extrabold text-white mb-2">
            Chào mừng trở lại! 👋
          </h1>
          <p class="text-indigo-100 text-lg max-w-2xl">
            Cùng kiểm tra xem tháng này chúng ta cần thanh toán những dịch vụ
            nào nhé. Kiểm soát chi tiêu thông minh hơn mỗi ngày.
          </p>
          <div class="mt-6">
            <a
              class="bg-white text-indigo-600 px-6 py-3 rounded-full font-bold shadow-md hover:shadow-lg hover:scale-105 transition-all duration-200 inline-flex items-center"
			  href="/add-service"
            >
              <svg
                class="w-5 h-5 mr-2"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 4v16m8-8H4"
                ></path>

              </svg>
              Thêm dịch vụ mới
            </a>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div
          class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow"
        >
          <h3
            class="text-gray-500 text-sm font-semibold uppercase tracking-wider mb-1"
          >
            Tổng chi phí tháng này
          </h3>
          <div class="text-3xl font-black text-gray-800">1,250,000 ₫</div>
        </div>

        <div
          class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow"
        >
          <h3
            class="text-gray-500 text-sm font-semibold uppercase tracking-wider mb-1"
          >
            Dịch vụ đang hoạt động
          </h3>
          <div class="text-3xl font-black text-gray-800">
            08 <span class="text-base font-normal text-gray-400">gói</span>
          </div>
        </div>

        <div
          class="bg-white p-6 rounded-2xl shadow-sm border border-red-100 bg-red-50 hover:shadow-md transition-shadow"
        >
          <h3
            class="text-red-500 text-sm font-semibold uppercase tracking-wider mb-1"
          >
            Sắp hết hạn (3 ngày tới)
          </h3>
          <div class="text-3xl font-black text-red-600 animate-pulse">
            02 <span class="text-base font-normal text-red-400">gói</span>
          </div>
        </div>
      </div>
    </main>
	<% } %>
  </body>
</html>
