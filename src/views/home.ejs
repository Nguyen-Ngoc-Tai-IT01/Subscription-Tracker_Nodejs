<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Trang chủ - SubTracker</title>
    <link rel="stylesheet" href="/stylesheets/output.css" />
  </head>

  <body
    class="bg-slate-50 font-sans antialiased text-gray-900 min-h-screen flex flex-col"
  >
    <%- include('layouts/header') %>

    <% if(!locals.user) { %>
    <%- include('introduce') %>
    <% } else { %>
    <main
      class="flex-1 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8 animate-fade-in-up"
    >
      <div
        class="bg-indigo-600 rounded-[2rem] p-8 sm:p-10 mb-10 shadow-xl shadow-indigo-200 relative overflow-hidden flex flex-col sm:flex-row justify-between items-center gap-6"
      >
        <div
          class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-white opacity-10 rounded-full blur-2xl"
        ></div>
        <div
          class="absolute bottom-0 left-0 -mb-16 -ml-16 w-48 h-48 bg-purple-500 opacity-20 rounded-full blur-xl"
        ></div>

        <div class="relative z-10 w-full sm:w-2/3">
          <h1 class="text-3xl sm:text-4xl font-extrabold text-white mb-3">
            Chào mừng trở lại, <%= user.username %>! 👋
          </h1>
          <p class="text-indigo-100 text-lg">
            Cùng kiểm tra xem tháng này chúng ta cần thanh toán những dịch vụ
            nào nhé. Kiểm soát chi tiêu thông minh hơn mỗi ngày.
          </p>
        </div>

        <div class="relative z-10 w-full sm:w-auto">
          <a
            href="/add-service"
            class="bg-white text-indigo-600 px-8 py-4 rounded-2xl font-bold shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300 w-full sm:w-auto flex items-center justify-center"
          >
            <svg
              class="w-6 h-6 mr-2"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 4v16m8-8H4"
              ></path>
            </svg>
            Thêm dịch vụ mới
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <div
          class="bg-white p-8 rounded-[2rem] shadow-sm border border-slate-100 hover:shadow-lg hover:border-indigo-100 transition-all"
        >
          <h3
            class="text-slate-400 text-sm font-bold uppercase tracking-wider mb-2"
          >
            Tổng chi phí tháng này
          </h3>
          <div class="text-4xl font-black text-slate-800">1,250,000 ₫</div>
        </div>

        <div
          class="bg-white p-8 rounded-[2rem] shadow-sm border border-slate-100 hover:shadow-lg hover:border-indigo-100 transition-all"
        >
          <h3
            class="text-slate-400 text-sm font-bold uppercase tracking-wider mb-2"
          >
            Dịch vụ đang hoạt động
          </h3>
          <div class="text-4xl font-black text-slate-800">
            08 <span class="text-xl font-bold text-slate-400">gói</span>
          </div>
        </div>

        <div
          class="bg-red-50 p-8 rounded-[2rem] shadow-sm border border-red-100 hover:shadow-lg transition-all relative overflow-hidden"
        >
          <h3
            class="text-red-500 text-sm font-bold uppercase tracking-wider mb-2"
          >
            Sắp hết hạn (3 ngày tới)
          </h3>
          <div class="text-4xl font-black text-red-600 animate-pulse">
            02 <span class="text-xl font-bold text-red-400">gói</span>
          </div>
          <svg
            class="absolute -right-4 -bottom-4 w-32 h-32 text-red-500 opacity-5"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path
              fill-rule="evenodd"
              d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
              clip-rule="evenodd"
            ></path>
          </svg>
        </div>
      </div>

      <h2 class="text-2xl font-black text-slate-800 mb-6 ml-2">
        Danh sách đăng ký
      </h2>

      <div
        class="bg-white rounded-[2rem] shadow-xl shadow-slate-200/50 border border-slate-100 overflow-hidden relative"
      >
        <div class="overflow-x-auto pb-4">
          <table class="w-full text-left border-collapse min-w-[800px]">
            <thead class="bg-slate-50 border-b border-slate-100">
              <tr>
                <th
                  class="py-5 px-8 text-xs font-bold text-slate-400 uppercase tracking-wider"
                >
                  Tên dịch vụ
                </th>
                <th
                  class="py-5 px-8 text-xs font-bold text-slate-400 uppercase tracking-wider"
                >
                  Số tiền
                </th>
                <th
                  class="py-5 px-8 text-xs font-bold text-slate-400 uppercase tracking-wider"
                >
                  Chu kỳ
                </th>
                <th
                  class="py-5 px-8 text-xs font-bold text-slate-400 uppercase tracking-wider"
                >
                  Ngày thanh toán
                </th>
                <th
                  class="py-5 px-8 text-xs font-bold text-slate-400 uppercase tracking-wider text-center"
                >
                  Mã QR
                </th>
                <th
                  class="py-5 px-8 text-xs font-bold text-slate-400 uppercase tracking-wider text-center"
                >
                  Trạng thái
                </th>
				<th 
				  class="py-5 px-8 text-xs font-bold text-slate-400 uppercase tracking-wider text-center w-20"
				>
				  Xóa
				</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% if (typeof services === 'undefined' || services.length === 0) { %>
              <tr>
                <td colspan="6" class="py-16 text-center">
                  <div
                    class="inline-flex items-center justify-center w-20 h-20 bg-slate-50 rounded-full mb-4"
                  >
                    <svg
                      class="w-10 h-10 text-slate-300"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"
                      ></path>
                    </svg>
                  </div>
                  <h3 class="text-lg font-bold text-slate-700 mb-1">
                    Chưa có dịch vụ nào
                  </h3>
                  <p class="text-slate-500 font-medium">
                    Bạn chưa theo dõi gói đăng ký nào. Hãy thêm dịch vụ mới nhé!
                  </p>
                </td>
              </tr>
              <% } else { %>
              <% services.forEach(function(item) { %>
              <tr
			    id="service-row-<%= item._id %>"
                class="hover:bg-slate-50 transition-colors group border-b border-slate-100 last:border-none"
              >
                <td class="py-5 px-8 flex items-center gap-4">
                  <div
                    class="w-12 h-12 rounded-2xl bg-gradient-to-br from-indigo-100 to-purple-100 text-indigo-600 flex items-center justify-center font-black text-xl shadow-inner border border-indigo-50 group-hover:scale-110 transition-transform duration-300"
                  >
                    <%= item.serviceName.charAt(0).toUpperCase() %>
                  </div>
                  <span
                    class="font-extrabold text-slate-800 text-lg group-hover:text-indigo-600 transition-colors"
                  >
                    <%= item.serviceName %>
                  </span>
                </td>

                <td class="py-5 px-8 font-bold text-slate-600">
                  <span
                    class="bg-slate-100 px-3 py-1.5 rounded-xl text-slate-700"
                  >
                    <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(item.price) %>
                  </span>
                </td>

                <td class="py-5 px-8">
                  <% if (item.billingCycle === 'yearly') { %>
                  <span
                    class="px-3 py-1.5 text-xs font-bold text-purple-700 bg-purple-100 rounded-xl border border-purple-200"
                    >Hàng năm</span
                  >
                  <% } else { %>
                  <span
                    class="px-3 py-1.5 text-xs font-bold text-indigo-700 bg-indigo-100 rounded-xl border border-indigo-200"
                    >Hàng tháng</span
                  >
                  <% } %>
                </td>

                <td class="py-5 px-8">
                  <div
                    class="inline-flex items-center gap-2 px-3 py-1.5 rounded-xl bg-slate-50 border border-slate-200 text-slate-600 font-bold"
                  >
                    <svg
                      class="w-4 h-4 text-slate-400"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                      ></path>
                    </svg>
                    <%= item.nextPaymentDate ? new Date(item.nextPaymentDate).toLocaleDateString('vi-VN') : 'Chưa cập nhật' %>
                  </div>
                </td>

                <td class="py-5 px-8 text-center">
                  <button
  					type="button"
  					onclick="openImageModal(`<%- item.QRCode ? '/images/' + item.QRCode : '/images/default-bill.jpg' %>`, `<%= item.serviceName %>`)"
  					class="p-2.5 text-indigo-500 bg-indigo-50 hover:bg-indigo-600 hover:text-white rounded-xl transition-all duration-300 shadow-sm border border-indigo-100 group-hover:border-transparent"
					>
                    <svg
                      class="w-5 h-5"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                      ></path>
                    </svg>
                  </button>
                </td>

                <td
                  class="py-5 px-8 text-center"
                  id="status-col-<%= item._id %>"
                >
                  <% if (item.status === 'paid') { %>
                  <button
                    disabled
                    class="px-4 py-2 bg-emerald-100 text-emerald-700 font-bold text-xs rounded-xl border border-emerald-200 cursor-default flex items-center gap-1.5 mx-auto"
                  >
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M5 13l4 4L19 7"
                      ></path>
                    </svg>
                    Đã thanh toán
                  </button>
                  <% } else { %>
                  <button
                    type="button"
                    onclick="
                      openConfirmModal(
                        '<%= item._id %>',
                        '<%= item.serviceName %>',
                      )
                    "
                    class="px-4 py-2 bg-rose-50 text-rose-600 font-bold text-xs rounded-xl border border-rose-200 hover:bg-rose-500 hover:text-white transition-all flex items-center gap-1.5 mx-auto"
                  >
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                      ></path>
                    </svg>
                    Chưa thanh toán
                  </button>
                  <% } %>
                </td>
				<td class="py-5 px-8 text-center">
            	<button 
                  type="button" 
                  onclick="openDeleteModal('<%= item._id %>', '<%= item.serviceName %>')"
                  class="p-2.5 text-slate-400 hover:text-rose-600 hover:bg-rose-50 rounded-xl transition-all duration-300 focus:outline-none"
                  title="Xóa dịch vụ">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                  </svg>
                </button>
          		</td>
              </tr>
              <% }); %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
    <% } %>
  </body>

  <!-- Hiển thị hình ảnh QR -->
  <div
    id="imageModal"
    class="fixed inset-0 z-[100] hidden items-center justify-center bg-slate-900/60 backdrop-blur-sm p-4 opacity-0 transition-opacity duration-300"
  >
    <div
      class="bg-white rounded-[2rem] p-4 sm:p-6 max-w-2xl w-full shadow-2xl transform scale-95 transition-transform duration-300"
      id="imageModalContent"
    >
      <div class="flex justify-between items-center mb-4 px-2">
        <h3 class="text-xl font-bold text-slate-800" id="modalImageTitle">
          Hình ảnh hóa đơn
        </h3>
        <button
          onclick="closeModals()"
          class="p-2 bg-slate-100 hover:bg-rose-100 hover:text-rose-600 rounded-full transition-colors"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"
            ></path>
          </svg>
        </button>
      </div>
      <div
        class="bg-slate-50 rounded-3xl overflow-hidden border border-slate-100 min-h-[300px] flex items-center justify-center"
      >
        <img
          id="modalImgTag"
          src=""
          alt="Hóa đơn"
          class="max-w-full max-h-[70vh] object-contain"
        />
      </div>
    </div>
  </div>
  <!-- Hiển thị xác nhận đã thanh toán -->
  <div
    id="confirmModal"
    class="fixed inset-0 z-[100] hidden items-center justify-center bg-slate-900/60 backdrop-blur-sm p-4 opacity-0 transition-opacity duration-300"
  >
    <div
      class="bg-white rounded-[2rem] p-8 max-w-md w-full shadow-2xl text-center transform scale-95 transition-transform duration-300"
      id="confirmModalContent"
    >
      <div
        class="w-20 h-20 bg-indigo-50 text-indigo-500 rounded-full flex items-center justify-center mx-auto mb-6"
      >
        <svg
          class="w-10 h-10"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
          ></path>
        </svg>
      </div>
      <h3 class="text-2xl font-black text-slate-800 mb-2">
        Xác nhận thanh toán?
      </h3>
      <p class="text-slate-500 font-medium mb-8">
        Bạn xác nhận đã thanh toán thành công cho dịch vụ
        <strong id="confirmServiceName" class="text-slate-700"></strong> chứ?
      </p>

      <div class="flex gap-4">
        <button
          onclick="closeModals()"
          class="flex-1 py-3.5 font-bold text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-2xl transition-all"
        >
          Hủy bỏ
        </button>
        <button
          onclick="submitPayment()"
          class="flex-1 py-3.5 font-bold text-white bg-indigo-600 hover:bg-indigo-700 rounded-2xl transition-all shadow-lg shadow-indigo-200"
        >
          Xác nhận
        </button>
      </div>
    </div>
  </div>
  <!-- Hiển thị xác nhận xóa dịch vụ -->
  <div id="deleteModal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-slate-900/60 backdrop-blur-sm p-4 opacity-0 transition-opacity duration-300">
    <div class="bg-white rounded-[2rem] p-8 max-w-md w-full shadow-2xl text-center transform scale-95 transition-transform duration-300" id="deleteModalContent">
        <div class="w-20 h-20 bg-rose-50 text-rose-500 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
        </div>
        <h3 class="text-2xl font-black text-slate-800 mb-2">Bạn chắc chắn muốn xóa?</h3>
        <p class="text-slate-500 font-medium mb-8">Dữ liệu về gói <strong id="deleteServiceName" class="text-rose-600"></strong> sẽ bị xóa vĩnh viễn và không thể khôi phục.</p>
        
        <div class="flex gap-4">
            <button onclick="closeModals()" class="flex-1 py-3.5 font-bold text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-2xl transition-all">Hủy bỏ</button>
            <button onclick="submitDelete()" class="flex-1 py-3.5 font-bold text-white bg-rose-600 hover:bg-rose-700 rounded-2xl transition-all shadow-lg shadow-rose-200">Đồng ý xóa</button>
        </div>
    </div>
  </div>


	<script>
		// lưu id
		let currentServiceId = null;
		let currentDeleteId = null;

		
		// đóng mở modal
		function showModal(modalId, contentId) {
			const modal = document.getElementById(modalId);
			const content = document.getElementById(contentId);
		
			modal.classList.remove("hidden");
			modal.classList.add("flex");

			setTimeout(() => {
				modal.classList.remove("opacity-0");
				content.classList.remove("scale-95");
			}, 10);
		}

		function closeModals() {
			['imageModal', 'confirmModal', 'deleteModal'].forEach(id => {
				const modal = document.getElementById(id);
				if (!modal) return; 
				
				const content = document.getElementById(id + 'Content');
				modal.classList.add('opacity-0');
				content.classList.add('scale-95');
				
				setTimeout(() => {
					modal.classList.add('hidden');
					modal.classList.remove('flex');
				}, 300);
			});
		}

		
		// xem QR
		function openImageModal(imgUrl, serviceName) {
			document.getElementById("modalImgTag").src = imgUrl;
			document.getElementById("modalImageTitle").innerText = "Hóa đơn: " + serviceName;
			showModal("imageModal", "imageModalContent");
		}

		// xác nhận thanh toán
		function openConfirmModal(id, serviceName) {
			currentServiceId = id;
			document.getElementById("confirmServiceName").innerText = serviceName;
			showModal("confirmModal", "confirmModalContent");
		}

		async function submitPayment() {
			try {
				const response = await fetch(`/service/pay/${currentServiceId}`, {
					method: "POST",
					headers: { 'Content-Type': 'application/json' }
				});

				if (response.ok) {
					closeModals();
					window.location.reload(); 
				} else {
					alert("Có lỗi xảy ra khi cập nhật Database!");
				}
			} catch (error) {
				console.error("Lỗi:", error);
				alert("Không thể kết nối đến máy chủ.");
			}
		}

		// xóa
		function openDeleteModal(id, serviceName) {
			currentDeleteId = id;
			document.getElementById('deleteServiceName').innerText = serviceName;
			showModal('deleteModal', 'deleteModalContent');
		}

		async function submitDelete() {
			try {
				const response = await fetch(`/service/${currentDeleteId}`, { 
					method: 'DELETE' 
				});

				if (response.ok) {
					const row = document.getElementById(`service-row-${currentDeleteId}`);
					if (row) {
						row.classList.add('opacity-0', '-translate-x-full'); 
						setTimeout(() => {
							row.remove(); 
						}, 300);
					}
					closeModals(); 
				} else {
					alert("Có lỗi xảy ra khi xóa trong Database!");
				}
			} catch (error) {
				console.error("Lỗi:", error);
				alert("Không thể kết nối đến máy chủ.");
			}
		}
	</script>
</html>
