<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký - SubTracker</title>
    <link rel="stylesheet" href="/stylesheets/output.css" />
  </head>

  <body
    class="bg-slate-50 font-sans antialiased text-gray-900 flex items-center justify-center min-h-screen py-8 px-4"
  >
    <div
      class="relative mt-10 max-w-md w-full px-6 py-10 bg-white rounded-3xl shadow-xl shadow-slate-200/50 border border-slate-100"
    >
      <div class="text-center mb-8">
        <h2 class="text-3xl font-black text-gray-800 tracking-tight">
          Tạo tài khoản mới
        </h2>
        <p class="text-gray-500 mt-2">
          Bắt đầu quản lý chi tiêu của bạn ngay hôm nay
        </p>
      </div>

      <form action="/sign_up" method="POST" class="space-y-5">
        <% if (locals.errorMessage) { %>
      <div class="flex items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-2xl text-red-600 shadow-sm">
        <svg class="w-5 h-5 flex-shrink-0 text-red-500" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
        </svg>
        <span class="font-semibold text-sm">
          <%= locals.errorMessage %>
        </span>
      </div>
      <% } %>
        <div>
          <label
            for="name"
            class="block text-sm font-semibold text-gray-700 mb-2 ml-1"
            >Họ và tên</label
          >
          <input
            type="text"
            id="name"
            name="username"
            required
            class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all placeholder:text-slate-400"
            placeholder="Nguyễn Văn A"
            value="<%= locals.oldUsername %>"
          />
        </div>

        <div>
          <label
            for="email"
            class="block text-sm font-semibold text-gray-700 mb-2 ml-1"
            >Email của bạn</label
          >
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all placeholder:text-slate-400"
            placeholder="name@example.com"
            value="<%= locals.oldEmail %>"
          />
        </div>

        <div>
          <label
            for="password"
            class="block text-sm font-semibold text-gray-700 mb-2 ml-1"
            >Mật khẩu</label
          >
          <input
            type="password"
            id="password"
            name="password"
            required
            class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all placeholder:text-slate-400"
            placeholder="••••••••"
          />
        </div>

        <div>
          <label
            for="confirmPassword"
            class="block text-sm font-semibold text-gray-700 mb-2 ml-1"
            >Xác nhận mật khẩu</label
          >
          <input
            type="password"
            id="confirmPassword"
            name="confirmPassword"
            required
            class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all placeholder:text-slate-400"
            placeholder="••••••••"
          />
        </div>

        <button
          type="submit"
          class="w-full bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-bold py-4 rounded-2xl shadow-lg shadow-indigo-200 hover:shadow-indigo-400 hover:scale-[1.02] active:scale-95 transition-all duration-200 mt-2"
        >
          Đăng ký miễn phí
        </button>
      </form>

      <p class="text-center mt-6 text-sm text-gray-500">
        Đã có tài khoản?
        <a href="/sign_in" class="font-bold text-indigo-600 hover:underline"
          >Đăng nhập ngay</a
        >
      </p>
    </div>
  </body>
</html>
 