<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 - Không tìm thấy trang | SubTracker</title>
    <link rel="stylesheet" href="/stylesheets/output.css" />
    <style>
      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
      }
      .animate-float {
        animation: float 3s ease-in-out infinite;
      }
    </style>
  </head>

  <body class="bg-slate-50 font-sans antialiased text-slate-900 min-h-screen flex flex-col items-center justify-center p-6">
    
    <div class="max-w-md w-full text-center">
      <!-- Icon 404 Minh họa -->
      <div class="relative mb-8 flex justify-center">
        <div class="w-48 h-48 bg-indigo-50 rounded-full flex items-center justify-center animate-float">
          <svg class="w-24 h-24 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 9.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <!-- <div class="absolute -top-2 -right-2 bg-rose-500 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg">
          Error 404
        </div> -->
      </div>

      <!-- Nội dung thông báo -->
      <h1 class="text-6xl font-black text-slate-800 mb-4 tracking-tighter">404</h1>
      <h2 class="text-2xl font-bold text-slate-700 mb-4">Trang bạn tìm không tồn tại</h2>
      <p class="text-slate-500 font-medium mb-10 leading-relaxed">
        Có vẻ như đường dẫn này đã bị hỏng, đã bị xóa hoặc bạn đã gõ nhầm địa chỉ. Hãy quay về "nhà" để tiếp tục quản lý chi tiêu nhé.
      </p>

      <!-- Nút hành động -->
      <div class="flex flex-col gap-4">
        <a href="/" class="w-full bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-bold py-4 rounded-2xl shadow-xl shadow-indigo-200 hover:shadow-indigo-300 hover:-translate-y-1 active:scale-95 transition-all duration-200 text-lg">
          Quay lại trang chủ
        </a>
        <button onclick="history.back()" class="w-full bg-white text-slate-600 font-bold py-4 rounded-2xl border border-slate-200 hover:bg-slate-50 transition-all">
          Trở về trang trước
        </button>
      </div>
    </div>

    <!-- Footer nhỏ -->
    <footer class="mt-16 text-slate-400 text-sm font-medium">
      &copy; 2026 SubTracker. Thiết kế bởi Nguyễn Ngọc Tài.
    </footer>

  </body>
</html>
