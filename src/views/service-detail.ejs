<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chi tiết: <%= service.serviceName %></title>
    <link rel="stylesheet" href="/stylesheets/output.css">
</head>
<body class="bg-slate-50 font-sans antialiased text-gray-900 min-h-screen flex flex-col">
    <%- include('layouts/header') %>

    <main class="flex-1 max-w-4xl w-full mx-auto px-4 py-12">
        <a href="/" class="inline-flex items-center text-indigo-600 font-bold mb-8 hover:text-indigo-800 transition-colors">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Quay lại trang chủ
        </a>

        <div class="bg-white rounded-[2.5rem] shadow-xl shadow-slate-200/60 overflow-hidden border border-slate-100">
            <div class="bg-indigo-600 p-10 text-white relative overflow-hidden">
                <div class="absolute top-0 right-0 w-64 h-64 bg-white opacity-5 rounded-full -mr-20 -mt-20"></div>
                <div class="relative z-10 flex flex-col md:flex-row justify-between items-center gap-6">
                    <div class="flex items-center gap-6">
                        <div class="w-20 h-20 bg-white/20 backdrop-blur-md rounded-3xl flex items-center justify-center text-4xl font-black">
                            <%= service.serviceName.charAt(0).toUpperCase() %>
                        </div>
                        <div>
                            <h1 class="text-4xl font-black mb-1"><%= service.serviceName %></h1>
                            <span class="px-4 py-1.5 bg-white/20 backdrop-blur-md rounded-full text-sm font-bold border border-white/30 uppercase tracking-widest">
                                <%= service.billingCycle === 'yearly' ? 'Hàng năm' : 'Hàng tháng' %>
                            </span>
                        </div>
                    </div>
                    <div class="text-center md:text-right">
                        <p class="text-indigo-100 text-sm font-bold uppercase mb-1">Giá gói dịch vụ</p>
                        <div class="text-4xl font-black mb-4">
                            <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(service.price) %>
                        </div>
                        <button onclick="openEditModal('<%= service._id %>', '<%= service.serviceName %>', '<%= service.price %>')" class="inline-flex items-center gap-2 px-5 py-2.5 bg-amber-500 hover:bg-amber-400 text-white text-sm font-bold rounded-xl shadow-lg shadow-amber-500/30 transition-all">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                            Chỉnh sửa thông tin
                        </button>
                    </div>
                </div>
            </div>

            <div class="p-10 grid grid-cols-1 md:grid-cols-2 gap-12">
                <div>
                    <h3 class="text-lg font-black text-slate-800 mb-6 flex items-center gap-2">
                        <span class="w-2 h-6 bg-indigo-500 rounded-full"></span>
                        Thông tin thanh toán
                    </h3>
                    
                    <div class="space-y-6">
                        <div class="flex justify-between items-center p-4 bg-slate-50 rounded-2xl border border-slate-100">
                            <span class="text-slate-500 font-bold">Trạng thái hiện tại:</span>
                            <% if (service.status === 'paid') { %>
                                <span class="text-emerald-600 font-black text-sm uppercase">Đã thanh toán</span>
                            <% } else { %>
                                <span class="text-rose-600 font-black text-sm uppercase">Đang chờ</span>
                            <% } %>
                        </div>
                        
                        <div class="flex justify-between items-center p-4 bg-slate-50 rounded-2xl border border-slate-100">
                            <span class="text-slate-500 font-bold">Kỳ thanh toán tới:</span>
                            <span class="text-slate-800 font-black">
                                <%= service.nextPaymentDate ? new Date(service.nextPaymentDate).toLocaleDateString('vi-VN') : 'Chưa rõ' %>
                            </span>
                        </div>

                        <div class="flex justify-between items-center p-4 bg-slate-50 rounded-2xl border border-slate-100">
                            <span class="text-slate-500 font-bold">Ngày tạo hồ sơ:</span>
                            <span class="text-slate-400 font-medium text-sm">
                                <%= new Date(service.createdAt).toLocaleString('vi-VN') %>
                            </span>
                        </div>
                    </div>
                </div>

                <div>
                    <h3 class="text-lg font-black text-slate-800 mb-6 flex items-center gap-2">
                        <span class="w-2 h-6 bg-purple-500 rounded-full"></span>
                        Hóa đơn & Mã QR
                    </h3>
                    <div class="aspect-square bg-slate-50 rounded-[2rem] border-2 border-dashed border-slate-200 flex items-center justify-center overflow-hidden p-4">
                        <% if (service.QRCode) { %>
                            <img src="/images/<%= service.QRCode %>" alt="QR Code" class="max-w-full max-h-full object-contain rounded-2xl shadow-lg">
                        <% } else { %>
                            <div class="text-center text-slate-300">
                                <svg class="w-16 h-16 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                <p class="font-bold">Chưa có ảnh</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('layouts/footer') %>

    <div id="editModal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-slate-900/60 backdrop-blur-sm p-4 opacity-0 transition-opacity duration-300">
      <div class="bg-white rounded-[2rem] p-8 max-w-md w-full shadow-2xl transform scale-95 transition-transform duration-300" id="editModalContent">
        <h3 class="text-2xl font-black text-slate-800 mb-6 text-center">Chỉnh sửa dịch vụ</h3>
        <form id="editForm" onsubmit="submitEdit(event)">
            <div class="mb-4">
                <label class="block text-sm font-bold text-slate-700 mb-2">Tên dịch vụ</label>
                <input type="text" id="editServiceName" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
            </div>
            <div class="mb-6">
                <label class="block text-sm font-bold text-slate-700 mb-2">Giá tiền (VNĐ)</label>
                <input type="number" id="editServicePrice" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
            </div>
            <div class="flex gap-4">
                <button type="button" onclick="closeModals()" class="flex-1 py-3.5 font-bold text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-2xl transition-all">Hủy bỏ</button>
                <button type="submit" class="flex-1 py-3.5 font-bold text-white bg-amber-500 hover:bg-amber-600 rounded-2xl transition-all shadow-lg shadow-amber-200">Cập nhật</button>
            </div>
        </form>
      </div>
    </div>

    <script>
        let currentEditId = null;

        function showModal(modalId, contentId) {
            const modal = document.getElementById(modalId);
            const content = document.getElementById(contentId);
            modal.classList.remove("hidden");
            modal.classList.add("flex");
            setTimeout(() => {
                modal.classList.remove("opacity-0");
                content.classList.remove("scale-95");
            }, 10);
        }

        function closeModals() {
            const modal = document.getElementById('editModal');
            if (!modal) return; 
            const content = document.getElementById('editModalContent');
            modal.classList.add('opacity-0');
            content.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }, 300);
        }

        function openEditModal(id, currentName, currentPrice) {
            currentEditId = id;
            document.getElementById('editServiceName').value = currentName;
            document.getElementById('editServicePrice').value = currentPrice;
            showModal('editModal', 'editModalContent');
        }

        async function submitEdit(event) {
            event.preventDefault(); 
            const newName = document.getElementById('editServiceName').value;
            const newPrice = document.getElementById('editServicePrice').value;

            try {
                // Đóng gói thông tin mới và gửi lên Server
                const response = await fetch(`/service/edit/${currentEditId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ serviceName: newName, price: newPrice })
                });

                if (response.ok) {
                    closeModals();
                    // Thành công thì F5 lại trang để lấy dữ liệu mới
                    window.location.reload(); 
                } else {
                    alert("Cập nhật thất bại!");
                }
            } catch (error) {
                console.error(error);
                alert("Lỗi kết nối máy chủ.");
            }
        }
    </script>
</body>
</html>